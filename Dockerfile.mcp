# Imagem do MCP server (ferramentas do agente). Mesmo codebase do backend,
# entrypoint diferente: fala MCP (streamable-HTTP) e chama o backend via REST.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /srv

COPY pyproject.toml ./
COPY src ./src
RUN pip install --no-cache-dir .

EXPOSE 8000

CMD ["python", "-m", "src.interfaces.mcp.server"]
