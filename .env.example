# Copie para .env e ajuste. O .env nunca e commitado (ver .gitignore).

# --- Banco (servico `database` do docker-compose) ---
POSTGRES_USER=khal
POSTGRES_PASSWORD=khal_local_dev
POSTGRES_DB=khal
POSTGRES_PORT=5432
# URL usada pela aplicacao (fora do compose, host = localhost)
DATABASE_URL=postgresql+psycopg://khal:khal_local_dev@localhost:5432/khal

# --- Seed determinístico (ver docs/domain/seed-design.md + SPEC-006) ---
SEED_RANDOM_SEED=42
SEED_HISTORY_MONTHS=24
# Comportamento de numero fora do seed na demo: default_persona | treat_as_unidentified
UNKNOWN_PHONE_BEHAVIOR=default_persona

# --- Personas do seed (SPEC-006): fonte única do seed E dos evals ---
# Formato: "Nome:telefone" (E.164 sem '+'), separados por ';'. >=1, ate ~100.
# Cada persona ganha um perfil determinístico (bairro, faturas, outage, multi-UC).
# Default = as 3 canônicas (evals com cenários conhecidos out-of-box).
# No seu .env local, troque pelos numeros reais de demo (NAO versionar numeros reais).
SEED_PERSONAS="Ana Souza:555199990001;Carlos Lima:555199990002;Joana Pereira:555199990003"

# --- Object storage das faturas (MinIO/S3 — SPEC-008/ADR-0009) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=faturas
# URL pública (proxy do gateway) das faturas: /files/{key}.
FILES_PUBLIC_BASE_URL=http://localhost/files

# --- Notificações proativas (SPEC-009/ADR-0005) + resolução LID (SPEC-015/SPEC-030) ---
NATS_URL=nats://nats:4222
# REST do Omni p/ envio de texto (proativo) E p/ resolver LID→telefone (find_customer).
# No sandbox, a Omni API roda no container `sandbox`, aliased como `omni` na khal-wanet.
OMNI_URL=http://omni:8882
# SPEC-030: key FIXA compartilhada — a Omni API usa OMNI_API_KEY do env como key primária
# (packages/api/src/services/api-keys.ts) e o backend autentica com a MESMA. Vazio = a Omni
# gera uma key efêmera por start e o backend dá 401 (resolução LID cai, exige reseed). Troque
# por um valor próprio no .env local; precisa só ser igual nos dois lados.
OMNI_API_KEY=omni_sk_0123456789abcdef0123456789abcdef
# OMNI_INSTANCE_ID vazio = resolve o LID entre TODAS as instâncias (o id é dinâmico por
# pareamento; ver SPEC-030/omni_chats.py). Preencha só p/ fixar uma instância específica.
OMNI_INSTANCE_ID=
